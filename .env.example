# URL du webhook n8n qui reçoit les inscriptions (email + profil),
# envoie l'ebook par email et enregistre le lead dans Google Sheets.
N8N_WEBHOOK_URL=https://n8n.maikagency.dev/webhook/ebook-prompt-engineering

# URL du webhook n8n qui crée une session de paiement Stripe Checkout
# pour le soutien "Offre-moi un café".
N8N_CHECKOUT_WEBHOOK_URL=https://n8n.maikagency.dev/webhook/bmc-checkout

# URL du webhook n8n qui reçoit le feedback (note + commentaire + email)
# et l'enregistre dans Google Sheets.
N8N_FEEDBACK_WEBHOOK_URL=https://n8n.maikagency.dev/webhook/ebook-feedback

# (Optionnel) URL publique du site, utilisée pour les balises Open Graph / canonical.
NEXT_PUBLIC_SITE_URL=https://maikagency-ebooks.vercel.app
